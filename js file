const inputDecimal = document.getElementById('numeroDecimal')
const baseSelecionada = document.getElementById('escolhaBase')
const botao = document.getElementById('btnConverter')
const textoResultado = document.getElementById('resultado');

botao.addEventListener('click', function() {
    let decimal = Number(inputDecimal.value);

    //Pegamos qual base o usuário escolheu (2, 8 ou 16)
    let base = Number(baseSelecionada.value);
     
    // A mágica: o toString usa a variável "base" para decidir o cálculo
    let convertido = decimal.toString(base).toUpperCase(); //toUpperCase deixa o Hexa bonitão (A,B,C...)

    //Ajustando o nome da base para o texto
    let nomeBase = base === 2 ? "binário" : base === 16 ? "Hexadecimal" : "Octal";

    textoResultado.innerText = `${decimal} em ${nomeBase} é: ${convertido}`;


});


//Capturando os novos elementos

const inputMassa = document.getElementById('massa-c');
const inputVel = document.getElementById('vel-c');
const btnFisica = document.getElementById('btnCalcularC');
const resFisica = document.getElementById('res-cinetica');




//Lógica de Energia Cinética

btnFisica.addEventListener('click', function() {
  let m = Number(inputMassa.value);
  let v = Number(inputVel.value);

 
  //Cálculo: Massa vezes velocidade ao quadrado, tudo dividido por 2

  let energia = (m * (v ** 2)) / 2;

  resFisica.innerText = `A Energia Cinética é ${energia.toFixed(2)} Joules`;
  



});
